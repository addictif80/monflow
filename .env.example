# ===========================================
# MONFLOW - Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# ===========================================

# --- Base de données ---
DATABASE_URL="postgresql://monflow:CHANGE_ME_DB_PASSWORD@postgres:5432/monflow"
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_USER=monflow
POSTGRES_DB=monflow

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- API ---
API_PORT=3001
API_SECRET=CHANGE_ME_VERY_LONG_SECRET_KEY_AT_LEAST_32_CHARS
JWT_SECRET=CHANGE_ME_ANOTHER_VERY_LONG_SECRET_KEY
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_KEY
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Navidrome ---
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASSWORD=CHANGE_ME_NAVIDROME_PASSWORD

# --- Deemix ---
DEEMIX_URL=http://deemix:6595

# --- Stripe (paiements) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_MONTHLY=price_CHANGE_ME_MONTHLY
STRIPE_PRICE_YEARLY=price_CHANGE_ME_YEARLY

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@monflow.fr
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="MonFlow <noreply@monflow.fr>"

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.monflow.fr
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
NEXT_PUBLIC_APP_NAME=MonFlow
NEXT_PUBLIC_APP_URL=https://monflow.fr

# --- Genius API (lyrics) ---
GENIUS_ACCESS_TOKEN=CHANGE_ME_GENIUS_TOKEN

# --- Domaine ---
DOMAIN=monflow.fr
ADMIN_EMAIL=admin@monflow.fr

# --- Suspension auto (jours) ---
PAYMENT_GRACE_PERIOD_DAYS=7
ACCOUNT_DELETION_DAYS=30
